  "regexPatterns": [
    {
      "id": "normalize_amzn_bill",
      "description": "Normalize AMZN bill variants",
      "pattern": "\\bamzn[\\s\\./-]*com[\\s\\./-]*bill\\b",
      "replacement": "amzn com bill"
    },
    {
      "id": "normalize_apple_bill",
      "description": "Normalize Apple bill variants",
      "pattern": "\\bapple[\\s\\./-]*com[\\s\\./-]*bill\\b",
      "replacement": "apple com bill"
    },
    {
      "id": "normalize_google_help_pay",
      "description": "Normalize Google help pay variants",
      "pattern": "\\bg[\\s\\./-]*co[\\s\\./-]*helppay\\b",
      "replacement": "g co helppay"
    },
    {
      "id": "normalize_apostrophes",
      "description": "Replace apostrophes with spaces to match alias convention (sam's -> sam s)",
      "pattern": "['’]",
      "replacement": " "
    },
    {
      "id": "normalize_separators",
      "description": "Replace common separators with spaces while preserving merchant words",
      "pattern": "[\\|_,;:]+",
      "replacement": " "
    },
    {
      "id": "remove_card_last4_phrase",
      "description": "Remove card-last-four wording",
      "pattern": "\\b(card|visa|mc|amex|discover)?\\s*(ending|end|last)\\s*(in|with)?\\s*\\d{4}\\b",
      "replacement": " "
    },
    {
      "id": "remove_date_mmdd",
      "description": "Remove slash dates often embedded in descriptions",
      "pattern": "\\b\\d{1,2}/\\d{1,2}(?:/\\d{2,4})?\\b",
      "replacement": " "
    },
    {
      "id": "remove_date_iso",
      "description": "Remove ISO-like dates",
      "pattern": "\\b\\d{4}-\\d{2}-\\d{2}\\b",
      "replacement": " "
    },
    {
      "id": "remove_phone_numbers",
      "description": "Remove US-style phone numbers",
      "pattern": "\\b(?:\\+?1[-.\\s]?)?\\(?\\d{3}\\)?[-.\\s]?\\d{3}[-.\\s]?\\d{4}\\b",
      "replacement": " "
    },
    {
      "id": "remove_mx_rfc",
      "description": "Mexican RFC tax id embedded in descriptors",
      "pattern": "\\brfc\\s*:?\\s*[a-z&]{3,4}\\d{6}[a-z0-9]{2,3}\\b",
      "replacement": " "
    },
    {
      "id": "remove_br_cnpj",
      "description": "Brazilian CNPJ (14-digit, dotted or plain) in descriptors",
      "pattern": "\\b\\d{2}\\.?\\d{3}\\.?\\d{3}/?\\d{4}-?\\d{2}\\b",
      "replacement": " "
    },
    {
      "id": "remove_br_cpf",
      "description": "Brazilian CPF (11-digit, dotted) in descriptors",
      "pattern": "\\b\\d{3}\\.\\d{3}\\.\\d{3}-\\d{2}\\b",
      "replacement": " "
    },
    {
      "id": "remove_do_rnc",
      "description": "Dominican RNC tax id wording in descriptors",
      "pattern": "\\brnc\\s*:?\\s*\\d{9,11}\\b",
      "replacement": " "
    },
    {
      "id": "remove_fx_amount",
      "description": "Embedded foreign-currency amounts (USD 12.34 / EUR 9,99 ...)",
      "pattern": "\\b(usd|eur|mxn|brl|dop|gbp)\\s*[\\d.,]+\\b",
      "replacement": " "
    },
    {
      "id": "remove_es_card_suffix",
      "description": "Spanish 'tarjeta *1234' / 'tarj. 1234' card fragments",
      "pattern": "\\btarj(eta)?\\.?\\s*\\*?\\d{4}\\b",
      "replacement": " "
    },
    {
      "id": "extract_br_installment",
      "description": "Brazilian installment marker PARC nn/nn — EXTRACT to installment metadata before removing; category rules use it via the br_installment_tag rule",
      "pattern": "\\bparc\\s*\\d{1,2}\\s*/\\s*\\d{1,2}\\b",
      "replacement": " "
    },
    {
      "id": "extract_br_parcela",
      "description": "Brazilian 'parcela nn' / 'nn de nn' installment wording — extract then remove",
      "pattern": "\\bparcela\\s*\\d{1,2}(\\s*de\\s*\\d{1,2})?\\b",
      "replacement": " "
    },
    {
      "id": "extract_mx_msi",
      "description": "Mexican months-without-interest marker (nn MSI) — extract then remove",
      "pattern": "\\b\\d{1,2}\\s*msi\\b",
      "replacement": " "
    },
    {
      "id": "remove_long_numbers",
      "description": "Remove long standalone numeric references",
      "pattern": "\\b\\d{5,}\\b",
      "replacement": " "
    },
    {
      "id": "remove_mixed_ref_ids",
      "description": "Remove common mixed alpha-number authorization/order IDs",
      "pattern": "\\b[a-z]{1,6}\\d{4,}[a-z0-9]*\\b",
      "replacement": " "
    },
    {
      "id": "remove_hash_refs",
      "description": "Remove hash/order reference fragments (8+ alphanumeric chars containing at least one digit)",
      "pattern": "[#\\*]?\\b(?=[a-z0-9]*\\d)[a-z0-9]{8,}\\b",
      "replacement": " "
    },
    {
      "id": "remove_urls_help_domains",
      "description": "Strip www./TLD/path from domains keeping the brand token (chewy.com -> chewy)",
      "pattern": "\\bwww\\.|\\.(?:com|net|org|io|co|do|us|app|mx|es)\\b(?:/[a-z0-9._~:/?#\\[\\]@!$&'()*+,;=-]*)?",
      "replacement": " "
    },
    {
      "id": "remove_trailing_state_zip",
      "description": "Remove trailing state + ZIP location suffix",
      "pattern": "\\b(?:al|ak|az|ar|ca|co|ct|de|dc|fl|ga|hi|id|il|in|ia|ks|ky|la|me|md|ma|mi|mn|ms|mo|mt|ne|nv|nh|nj|nm|ny|nc|nd|oh|ok|or|pa|ri|sc|sd|tn|tx|ut|vt|va|wa|wv|wi|wy)\\s+\\d{5}(?:-\\d{4})?\\b$",
      "replacement": " "
    },
    {
      "id": "remove_leading_card_noise",
      "description": "Remove common leading bank/card words",
      "pattern": "^(?:visa|mastercard|mc|amex|discover|debit|credit|card|purchase|pos|dda|pur|chkcard|checkcard)\\s+",
      "replacement": " "
    },
    {
      "id": "strip_repeated_punctuation",
      "description": "Collapse repeated punctuation/separators",
      "pattern": "[\\*\\.\\-/]{2,}",
      "replacement": " "
    },
    {
      "id": "collapse_whitespace",
      "description": "Collapse multiple whitespace characters",
      "pattern": "\\s+",
      "replacement": " "
    }
  ],
  "cleaningGuidance": {
    "important": "Do not remove preserveTerms before merchant matching. Some short tokens like BP, GAP, MTA, FPL, BHD are real merchants or organizations.",
    "recommendedOrder": [
      "lowercase",
      "run targeted normalization regexes",
      "extract processor prefix if present",
      "remove long reference ids",
      "remove common phrases",
      "remove exact noise words except preserveTerms",
      "collapse whitespace",
      "run merchant alias matching",
      "then optionally remove location suffix tokens"
    ],
    "rawDataRule": "Always keep rawDescription separately. Store cleanedDescription and enriched fields as derived data.",
    "diacritics": "Strip accents/diacritics BEFORE matching: all aliases in this pack are stored unaccented (sao paulo, cafeteria, farmacia). In Swift use String.folding(options: [.diacriticInsensitive, .caseInsensitive], locale: nil).",
    "installments": "Run extract_br_installment / extract_br_parcela / extract_mx_msi patterns as EXTRACTORS: capture the value into transaction metadata (installment 3/10), then remove from the cleaned text.",
    "locationSuffixOrder": "brazilianStates two-letter codes (sp, rj, es...) collide with English words and the 'es' country code — only strip them as a TRAILING token after city names, never mid-string."
  }
}
