---
import { readFileSync } from 'node:fs';
import { join } from 'node:path';
import Layout from '../layouts/Layout.astro';
import IntegrateCard from '../components/IntegrateCard';

// Generated by scripts/sync-data.mjs (predev/prebuild), so it always exists here.
const index = JSON.parse(readFileSync(join(process.cwd(), 'public/data/index.json'), 'utf8'));
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const fmtBytes = (n: number) => (n >= 1024 * 1024 ? `${(n / 1024 / 1024).toFixed(1)} MB` : `${Math.round(n / 1024)} KB`);
const fmtCounts = (c: Record<string, number> | null) =>
  c ? Object.entries(c).map(([k, v]) => `${v} ${k}`).join(' · ') : '—';
---

<Layout title="Data API" active="data">
  <div class="max-w-4xl space-y-6">
    <div>
      <h1 class="mb-2 text-2xl font-bold text-white">Data API</h1>
      <p class="text-sm text-zinc-400">
        Every data file is served as a plain, public JSON asset — your app can fetch them directly
        instead of bundling them. CORS is open (<code class="text-zinc-300">Access-Control-Allow-Origin: *</code>),
        and GitHub Pages caches responses for ~10 minutes with ETags.
      </p>
    </div>

    <div class="card space-y-2">
      <p class="label">License &amp; attribution — required</p>
      <p class="text-sm text-zinc-400">
        The dataset is licensed under <a class="text-emerald-400 hover:underline" href="https://github.com/jtvargas/merchant-studio/blob/main/data/LICENSE" target="_blank">CC BY 4.0</a> —
        free for any purpose, including commercially, as long as you credit it. Show this credit somewhere your
        app displays data sources (About/Settings screen, footer, "powered by" line):
      </p>
      <div class="flex flex-wrap items-center gap-2">
        <code class="rounded-lg bg-zinc-950 px-3 py-1.5 text-sm text-emerald-300">Enrichment from Merchant Studio by Jonathan Taveras</code>
        <button type="button" class="btn copy-url" data-url="Enrichment from Merchant Studio by Jonathan Taveras">📋 Copy attribution</button>
      </div>
      <p class="text-xs text-zinc-500">
        Link it to <code>https://github.com/jtvargas/merchant-studio</code> where your UI supports links. Full
        terms and a short-form alternative: <a class="text-emerald-400 hover:underline" href="https://github.com/jtvargas/merchant-studio/blob/main/data/ATTRIBUTION.md" target="_blank">data/ATTRIBUTION.md</a>.
      </p>
    </div>

    <div class="card space-y-2">
      <p class="label">Discovery index — fetch this first</p>
      <div class="flex flex-wrap items-center gap-2">
        <code class="rounded-lg bg-zinc-950 px-3 py-1.5 text-sm text-emerald-300">{index.baseUrl}index.json</code>
        <button type="button" class="btn copy-url" data-url={`${index.baseUrl}index.json`}>📋 Copy URL</button>
        <a class="btn" href={`${base}/data/index.json`} target="_blank">Open</a>
      </div>
      <p class="text-xs text-zinc-500">
        Lists all {index.files.length} files with their URL, size, and <code>sha256</code> — schema
        <code>{index.schemaVersion}</code>, pack hash <code class="font-mono">{index.packHash.slice(0, 12)}…</code>
      </p>
    </div>

    <div class="overflow-x-auto rounded-xl border border-zinc-800">
      <table class="w-full text-left text-sm">
        <thead class="bg-zinc-900 text-xs uppercase tracking-wide text-zinc-500">
          <tr>
            <th class="px-3 py-2">File</th>
            <th class="px-3 py-2">Contents</th>
            <th class="px-3 py-2">Counts</th>
            <th class="px-3 py-2">Size</th>
            <th class="px-3 py-2">sha256</th>
            <th class="px-3 py-2"></th>
          </tr>
        </thead>
        <tbody>
          {index.files.map((f: any) => (
            <tr class="border-t border-zinc-800/60 align-top">
              <td class="px-3 py-2 whitespace-nowrap">
                <a class="font-mono text-emerald-400 hover:underline" href={`${base}/data/${f.path}`} target="_blank">{f.name}</a>
              </td>
              <td class="px-3 py-2 text-zinc-400">{f.description}</td>
              <td class="px-3 py-2 whitespace-nowrap text-zinc-400">{fmtCounts(f.counts)}</td>
              <td class="px-3 py-2 whitespace-nowrap text-zinc-400">{fmtBytes(f.bytes)}</td>
              <td class="px-3 py-2 font-mono text-xs text-zinc-500" title={f.sha256}>{f.sha256.slice(0, 12)}…</td>
              <td class="px-3 py-2">
                <button type="button" class="btn copy-url whitespace-nowrap" data-url={f.url}>📋 URL</button>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>

    <div class="card space-y-3">
      <h2 class="text-lg font-bold text-white">How to consume from an app</h2>
      <ol class="list-decimal space-y-1 pl-5 text-sm text-zinc-300">
        <li>Fetch <code>index.json</code> and compare its <code>packHash</code> with the one you stored — if equal, nothing changed.</li>
        <li>Otherwise diff each file's <code>sha256</code> against your stored copy and download only the changed files, resolving <code>path</code> against the index URL.</li>
        <li>Verify the downloaded bytes' sha256 matches the index entry before swapping it in — right after a deploy the CDN can briefly serve a mixed cache (~10 min); on mismatch keep your previous copy and retry later.</li>
      </ol>
      <pre class="overflow-x-auto rounded-lg bg-zinc-950 p-3 text-xs text-zinc-300"><code>{`const INDEX_URL = '${index.baseUrl}index.json';

const index = await (await fetch(INDEX_URL)).json();
if (index.packHash !== stored.packHash) {
  for (const f of index.files.filter((f) => f.sha256 !== stored.hashes[f.name])) {
    const bytes = await (await fetch(new URL(f.path, INDEX_URL))).arrayBuffer();
    const digest = await crypto.subtle.digest('SHA-256', bytes);
    const hex = [...new Uint8Array(digest)].map((b) => b.toString(16).padStart(2, '0')).join('');
    if (hex === f.sha256) save(f.name, bytes, hex); // else keep old copy, retry later
  }
}`}</code></pre>
      <p class="text-xs text-zinc-500">
        A Swift (URLSession + Codable) version lives in the
        <a class="text-emerald-400 hover:underline" href="https://github.com/jtvargas/merchant-studio#use-the-data-in-your-app-public-data-api" target="_blank">README</a>.
        The 6 source files are also readable at
        <code>raw.githubusercontent.com/jtvargas/merchant-studio/main/data/…</code>, but
        <code>index.json</code> only exists here — it's generated at build time.
      </p>
    </div>

    <div class="card space-y-3">
      <div>
        <h2 class="text-lg font-bold text-white">Integrate in your app — let an LLM build the client</h2>
        <p class="text-sm text-zinc-400">
          Pick your stack and copy a complete implementation brief: data models, the exact matching
          algorithm, caching contract, and acceptance tests. Paste it into your AI assistant and review the result.
        </p>
      </div>
      <IntegrateCard client:load />
    </div>
  </div>

  <script>
    document.querySelectorAll<HTMLButtonElement>('.copy-url').forEach((btn) => {
      btn.addEventListener('click', async () => {
        await navigator.clipboard.writeText(btn.dataset.url!);
        const original = btn.textContent;
        btn.textContent = '✓ Copied';
        setTimeout(() => { btn.textContent = original; }, 1500);
      });
    });
  </script>
</Layout>
