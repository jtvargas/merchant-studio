---
import '../styles/global.css';
import ModeBadge from '../components/ModeBadge';

interface Props {
  title: string;
  active: string;
}
const { title, active } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const nav = [
  ['/', 'Dashboard', 'dashboard'],
  ['/merchants', 'Merchants', 'merchants'],
  ['/add', 'Add merchant', 'add'],
  ['/playground', 'Playground', 'playground'],
  ['/tests', 'Test set', 'tests'],
  ['/validate', 'Validate', 'validate'],
  ['/rules', 'Rules', 'rules'],
  ['/mcc', 'MCC', 'mcc'],
  ['/data', 'Data API', 'data'],
] as const;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link
      rel="icon"
      href={`data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>🏪</text></svg>`}
    />
    <title>{title} · Merchant Studio</title>
  </head>
  <body>
    <div class="mx-auto flex min-h-screen max-w-7xl flex-col px-4">
      <header class="flex flex-wrap items-center gap-x-6 gap-y-2 border-b border-zinc-800 py-4">
        <a href={`${base}/`} class="flex items-center gap-2 text-lg font-bold text-white">
          <span>🏪</span> Merchant Studio
        </a>
        <nav class="flex flex-wrap gap-1 text-sm">
          {
            nav.map(([href, label, key]) => (
              <a
                href={`${base}${href}`}
                class:list={[
                  'rounded-lg px-3 py-1.5 transition-colors',
                  key === active
                    ? 'bg-emerald-600/20 text-emerald-300 font-semibold'
                    : 'text-zinc-400 hover:bg-zinc-800 hover:text-zinc-200',
                ]}
              >
                {label}
              </a>
            ))
          }
        </nav>
        <div class="ml-auto">
          <ModeBadge client:load />
        </div>
      </header>
      <main class="flex-1 py-6">
        <slot />
      </main>
      <footer class="border-t border-zinc-800 py-4 text-xs text-zinc-500">
        Transaction enrichment pack · schema 1.1.0 · data lives in <code>data/</code> — commit &amp; push after editing locally
      </footer>
    </div>
  </body>
</html>
